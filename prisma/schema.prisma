generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id @default(uuid())
  name           String?
  email          String     @unique
  password       String
  avatar         String?
  avatarPublicId String?
  createdAt      DateTime   @default(now())
  pins           Pin[]
  savedPins      SavedPin[]
  boards         Board[]
}

model Pin {
  id          String     @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  publicId    String
  userID      String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userID], references: [id], onDelete: Cascade)
  savedPins   SavedPin[]
}

model SavedPin {
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinId   String
  pin     Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())
  boardId String
  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@id([boardId, pinId])
}

model Board {
  id        String     @id @default(uuid())
  name      String
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedPins SavedPin[]
  createdAt DateTime   @default(now())
}
